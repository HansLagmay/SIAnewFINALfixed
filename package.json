{
  "name": "tes-property-system-v2",
  "version": "2.0.0",
  "description": "TES Property System - Real Estate Inquiry Management System",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "cd server && npm run dev",
    "client": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "start": "cd server && npm start",
    "install-all": "npm install && cd client && npm install && cd ../server && npm install"
  },
  "keywords": [
    "real-estate",
    "property-management",
    "inquiry-system"
  ],
  "author": "TES Property",
  "license": "MIT",
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^8.2.2",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
